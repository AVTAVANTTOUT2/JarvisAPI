{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ES2022"
    ],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "preserveSymlinks": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@frontend/*": [
        "./src/*"
      ],
      "@unified/*": [
        "./src/*"
      ],
      "@desktop/*": [
        "../web/src/*"
      ],
      "@mobile/*": [
        "../pwa/src/*"
      ],
      "react": [
        "./node_modules/@types/react/index.d.ts"
      ],
      "react/jsx-runtime": [
        "./node_modules/@types/react/jsx-runtime.d.ts"
      ],
      "react/jsx-dev-runtime": [
        "./node_modules/@types/react/jsx-dev-runtime.d.ts"
      ],
      "react-dom": [
        "./node_modules/@types/react-dom/index.d.ts"
      ],
      "react-dom/*": [
        "./node_modules/@types/react-dom/*"
      ],
      "react-router": [
        "./node_modules/react-router/dist/development/index.d.mts"
      ],
      "react-router-dom": [
        "./node_modules/react-router-dom/dist/index.d.mts"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "../web/src/vite-env.d.ts",
    "../jarvis_auth/src/**/*.ts",
    "../jarvis_auth/src/**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
