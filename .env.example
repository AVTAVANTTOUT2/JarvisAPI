# ═══════════════════════════════════════════════════════════
# JARVIS — Variables d'environnement
# Copie ce fichier en .env et remplis tes clés.
# ═══════════════════════════════════════════════════════════

# ── DeepSeek API (OBLIGATOIRE) ───────────────────────────────
# Format compatible OpenAI. Inscription : https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_FAST_MODEL=deepseek-v4-flash  # rapide : classification, triage, voix, auto-titre, mémoire
DEEPSEEK_MAIN_MODEL=deepseek-v4-pro    # principal : coach, journal, productivité, école

# ── Tâches lourdes ──────────────────────────────────────────
# Productions longues (dissertations, exercices complets, code, rapports) :
# DEEPSEEK_MAIN_MODEL avec plafond de tokens élevé.
HEAVY_TASK_MAX_TOKENS=8192

# ── Dual-LLM (package jarvis/) — LOCAL MLX + DeepSeek ───────
# LOCAL = messages d'Elias (jamais hors du Mac). DeepSeek = mail/RAG/tâches/docs
# après anonymisation PII. NE JAMAIS mettre la clé DeepSeek dans le code source.
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-pro
JARVIS_LOCAL_MODEL=mlx-community/Qwen3-30B-A3B-4bit
JARVIS_VENV=~/mlx-env
# Anonymisation : spaCy pour le NER (modèle fr). false = fallback regex pur.
JARVIS_PII_USE_SPACY=true
JARVIS_SPACY_MODEL=fr_core_news_sm

# ── Audio (local par défaut : Whisper Turbo + Kokoro) ────────
TTS_ENGINE=kokoro                              # kokoro | edge | ttskit | macos
TTS_VOICE=fr-FR-VivienneMultilingualNeural   # voix Edge TTS (si TTS_ENGINE=edge)
KOKORO_VOICE=af_nicole                       # voix Kokoro (si TTS_ENGINE=kokoro)
KOKORO_LANG=fr-fr                            # langue Kokoro (fr-fr, en-us, etc.)
MACOS_TTS_VOICE=Thomas

STT_ENGINE=faster-whisper
STT_MODEL=large-v3-turbo
STT_LANGUAGE=fr
STT_DEVICE=auto
STT_COMPUTE_TYPE=auto
STT_ALLOW_MODEL_DOWNLOAD=false
STT_FALLBACK_MODEL=large-v3

WAKE_WORD=jarvis

# ── Conversation vocale (page /voice) ───────────────────────
# Détection de fin de parole côté navigateur (Web Audio API AnalyserNode).
VOICE_SILENCE_DURATION_MS=1200  # ms de silence avant fin de phrase (client)
VOICE_MIN_SPEECH_MS=400         # durée min de parole pour être traitée
VOICE_MAX_TOKENS=500            # tokens max pour les réponses vocales

# ── Écoute continue (page /voice — enregistrement long) ─────
# Max durée (minutes) refusée au-delà ; segments locaux ; masquer la transcription si besoin.
RECORDING_MAX_DURATION_MIN=180
RECORDING_CHUNK_SIZE_MB=20
RECORDING_SUMMARY_ONLY=false

# ── Localisation (GPS, lieux nommés) ───────────────────────
# L’app / Raccourcis iOS envoie des points sur POST /api/location
LOCATION_TRACKING=true
LOCATION_PLACE_RADIUS=100

# ── Intégrations (Phase 4) ──────────────────────────────────
# Mail : lu via Apple Mail (Mail.app) en AppleScript — aucune config nécessaire.
# Il suffit que Mail.app soit configuré avec ton compte Gmail/iCloud/etc.
# et que Terminal ait la permission Automation (accordée au 1er lancement).

# Apple Mail (Mail.app) + Apple Calendar (Calendar.app) : aucune variable OAuth.
# Il suffit que les apps macOS soient configurées (comptes iCloud/Gmail/etc.).
# Réglages > Confidentialité > Automation pour Terminal au premier osascript.

# ── Notifications bureau macOS ─────────────────────────────
DESKTOP_NOTIFICATIONS=true       # bandeaux système (display notification)
NOTIFICATION_SOUND=Glass         # Glass, Ping, Pop, Sosumi…

WEATHER_API_KEY=              # OpenWeatherMap (https://openweathermap.org/api) — gratuit
WEATHER_CITY=Lille
TAVILY_API_KEY=               # Recherche web (https://tavily.com) — Phase ultérieure

# ── iMessage (macOS uniquement) ─────────────────────────────
# JARVIS lit chat.db et envoie via osascript (AppleScript).
# Setup :
#   1. Réglages Système > Confidentialité > Accès complet au disque
#      → ajouter Terminal/iTerm
#   2. Lancer JARVIS, accepter la permission Automation au 1er envoi
#   3. Envoyer un iMessage à ton propre numéro depuis ton iPhone → JARVIS répond
IMESSAGE_TARGET=              # ton numéro (+33...) ou email iMessage — vide = désactivé
IMESSAGE_POLLING_INTERVAL=3   # secondes entre chaque check de chat.db
IMESSAGE_PREFIX=              # vide = traite tous les messages
                              # défini (ex: "jarvis") = traite seulement les msgs commençant par ce mot

# ── iMessage — sourcing (lecture) et envoi (séparés) ──────
# IMESSAGE_SOURCING_ENABLED : scan chat.db en lecture seule → DB + analyse relationnelle
# IMESSAGE_SEND_ENABLED : envoi via osascript → RuntimeError si false (défaut)
# IMESSAGE_SCAN_INTERVAL : secondes entre 2 scans sourcing (défaut 300 = 5min)
IMESSAGE_SOURCING_ENABLED=true
IMESSAGE_SEND_ENABLED=false
IMESSAGE_SCAN_INTERVAL=300

# ── Import iMessage — chat.db → jarvis.db ───────────────────
# IIMPORT_BATCH_SIZE : messages par batch lors de l'import initial
# IIMPORT_MAX_RETRIES : tentatives max en cas d'echec sur un batch
# IIMPORT_SYNC_INTERVAL : secondes entre 2 syncs automatiques (si activee)
IIMPORT_BATCH_SIZE=5000
IIMPORT_MAX_RETRIES=3
IIMPORT_SYNC_INTERVAL=300

# ── Daemon iMessage — processus permanent d'accès à chat.db ──
# Execute hors Cursor (launchd), unique composant autorise a ouvrir chat.db.
# Tous les autres composants passent par son API HTTP locale (127.0.0.1).
IMESSAGE_DAEMON_ENABLED=true          # demarrage auto au lancement du supervisor
IMESSAGE_DAEMON_URL=http://127.0.0.1:8193
IMESSAGE_DAEMON_PORT=8193

# ── Système ─────────────────────────────────────────────────
DB_PATH=./data/jarvis.db
UPLOAD_DIR=./data/uploads
SCHOOL_OUTPUT_DIR=./data/outputs/school
DEV_PROJECTS_ROOT=./dev_projects
DEVAGENT_EXEC_TIMEOUT=120
DEV_PROJECTS_ROOT=./dev_projects
DEVAGENT_EXEC_TIMEOUT=120   # fichiers générés (exos, dissertations…)
USER_NAME=Nolann
LANGUAGE=fr
TIMEZONE=Europe/Paris
# Port UI (8081 si 8080 est pris, ex. whisper). Si « connexion refusée » sur localhost, essayez aussi http://127.0.0.1:PORT
WEB_PORT=8080
# Adresse d’écoute (défaut : toutes les interfaces IPv4). Voir README si « connexion refusée » avec localhost.
WEB_HOST=0.0.0.0

# === Accès ordinateur (macOS) ===
COMPUTER_ACCESS=true
COMPUTER_SHELL=/bin/zsh
COMPUTER_TIMEOUT=30

# === Contrôle TV (ADB + Wake-on-LAN + Google Cast fallback) ===
# La TV Philips entre en deep standby apres 5-10 min d'arret.
# WoL ne fonctionne plus dans cet etat → Google Cast prend le relais.
# Pre-requis TV : Reglages > Tous les reglages > Sans fil et reseaux
#   > Filaire ou Wi-Fi > Activer avec Wi-Fi (WoWLAN) = Active
#   > Activer avec Chromecast = Active
# Pre-requis Mac : pip install catt
# TV_IP=192.168.3.82              # IP de la TV Philips Android
# TV_ADB_PORT=5555                 # port ADB
# TV_MAC=f0:ed:51:02:16:34        # adresse MAC pour Wake-on-LAN
# TV_CAST_ENABLED=true             # fallback Google Cast si WoL echoue (deep standby)
# TV_CAST_TIMEOUT=20               # timeout catt en secondes
# TV_DASHBOARD_URL=http://192.168.3.52:5174/  # URL ouverte via Chromecast

# === Exécution de code avancée ===
CODE_EXECUTOR_ENABLED=true       # exécution de code avancée (tâches multi-étapes)
CODE_EXECUTOR_TIMEOUT=120        # timeout en secondes
CODE_EXECUTOR_MODEL=             # modèle utilisé (défaut: Sonnet)

# ── Mode autonome /loop (DeepSeek, sans limite par défaut) ──
# LOOP_UNLIMITED=true → pas de plafond utilisateur (garde-fou technique 500 étapes).
# Mettre une valeur > 0 pour limiter steps / chars / appels LLM.
LOOP_UNLIMITED=true
LOOP_MAX_STEPS=0
LOOP_MAX_OUTPUT_CHARS=0
LOOP_MAX_LLM_CALLS=0
LOOP_MAX_TOKENS=1024
LOOP_MAX_CONSECUTIVE_FAILURES=3
LOOP_MODEL=
LOOP_DECISION_MODEL=

# ── Briefings (Phase 4) ─────────────────────────────────────
MORNING_BRIEFING_TIME=07:30
EVENING_SUMMARY_TIME=22:00

# ── Surveillance email proactive ────────────────────────────
# Intervalle (en secondes) entre chaque scan des nouveaux mails non lus.
# Chaque mail est analysé par Haiku → tâches/rappels/notifications automatiques.
# Coût : ~$0.001 par email analysé. Défaut : 120 (2 minutes).
EMAIL_CHECK_INTERVAL=120

# ═══════════════════════════════════════════════════════════
# ── Daemon JARVIS (sentinelle permanente) ──────────────────
# ═══════════════════════════════════════════════════════════
# Le daemon tourne en parallèle du serveur web. Il surveille
# l'écran, les iMessages, les mails, le calendrier, et peut
# parler vocalement (TTS local). 95 % du travail tourne via
# Ollama local — coût LLM API = 0 token sur ces étapes.

DAEMON_ENABLED=true              # active la sentinelle permanente
SCREEN_WATCHER_ENABLED=true      # analyse de l'écran (capture + diff + LLM vision)
SCREEN_WATCHER_INTERVAL=15       # secondes entre chaque capture
SCREEN_CHANGE_THRESHOLD=5        # % de pixels changés minimum pour noter une activité
SCREEN_ANALYSIS_THRESHOLD=30     # % pour déclencher l'analyse LLM vision
SCREEN_MAX_ANALYSIS_WIDTH=768    # largeur max du crop envoyé à Ollama vision (pixels)
SCREEN_JPEG_QUALITY=55           # qualité JPEG des images envoyées
SCREEN_OLLAMA_MIN_INTERVAL_S=60  # délai minimum entre 2 analyses vision (anti-OOM kill)
SCREEN_VISION_MODEL=qwen3-vl:4b  # modèle Ollama vision
TRIAGE_MODEL=qwen2.5:7b          # modèle Ollama léger pour le triage des notifications
OLLAMA_URL=http://localhost:11434

# ── Identité de la machine ─────────────────────────────────
DEVICE_ID=                       # vide = hostname système (scutil --get LocalHostName)
DEVICE_NAME=Mac Mini M4

# ── Wake word "Jarvis" (Porcupine / Picovoice) ─────────────
# Inscription gratuite sur https://console.picovoice.ai
WAKE_WORD_ENABLED=false          # active la détection "Jarvis" en continu
PORCUPINE_ACCESS_KEY=

# ── Notifications vocales ──────────────────────────────────
DAEMON_TTS_COOLDOWN=15           # secondes minimum entre 2 notifications vocales en mode veille

# ── Audio Daemon (micro natif Mac Mini) ─────────────────
# Écoute en continu le micro du Mac, détecte le wake word "Jarvis",
# transcrit, appelle le backend, et joue la réponse sur les enceintes.
# Coexiste avec la page /voice web — micros différents, même backend.
AUDIO_DAEMON_ENABLED=false
AUDIO_DAEMON_SAMPLE_RATE=48000
AUDIO_DAEMON_SPEECH_THRESHOLD=0.02    # RMS seuil de parole (0.0–1.0)
AUDIO_DAEMON_SILENCE_MS=450           # ms de silence avant fin de phrase
AUDIO_DAEMON_MIN_SPEECH_MS=200        # durée minimale de parole
AUDIO_DAEMON_MAX_UTTERANCE_S=30       # durée max d'une utterance (flush forcé)
AUDIO_DAEMON_CONVERSATION_TIMEOUT=30.0
AUDIO_DAEMON_PRE_ROLL_MS=300          # pré-roll conservé avant début de parole
AUDIO_DAEMON_HALF_DUPLEX=true         # micro coupé pendant TTS (stabilité anti-écho)
AUDIO_DAEMON_INPUT_DEVICE=Blue Snowball
AUDIO_DAEMON_WAKE_SOUND=true
AUDIO_DAEMON_STT_ENGINE=faster-whisper  # faster-whisper | whisperkit | whispercpp | local (alias)
AUDIO_DAEMON_STT_MODEL=large-v3-turbo
AUDIO_DAEMON_STT_FALLBACK_MODEL=large-v3
AUDIO_DAEMON_WHISPERCPP_MODEL_PATH=~/models/ggml-large-v3.bin
AUDIO_DAEMON_ALLOW_MODEL_DOWNLOAD=false # jamais de téléchargement pendant une conversation
SILERO_VAD_THRESHOLD=0.42
SILERO_VAD_THRESHOLD_OFF=0.28
TTS_MODEL=qwen3-tts-0.6b              # TTSKit (pipeline natif)
TTS_LANGUAGE=fr
TTS_MODEL_PATH=                       # chemin local optionnel TTSKit
PORCUPINE_ACCESS_KEY=                 # cle gratuite sur https://console.picovoice.ai
# Sans cle Porcupine, le wake word est remplace par detection de volume (moins fiable)

# ── Fiabilité — sauvegardes, rétention, budget LLM, heures calmes ──
BACKUP_ENABLED=true            # sauvegarde SQLite quotidienne (04:15)
BACKUP_DIR=./data/backups
BACKUP_KEEP=7                  # nb de sauvegardes conservées (rotation)
RETENTION_SCREEN_DAYS=30       # purge screen_activity (0 = conserver tout)
RETENTION_LOCATION_DAYS=90     # purge location_history
RETENTION_NOTIF_READ_DAYS=60   # purge notifications LUES uniquement
RETENTION_LLM_LOGS_DAYS=90     # purge llm_action_logs
LLM_BUDGET_MONTHLY=20          # budget mensuel $ (0 = pas d'alerte)
LLM_BUDGET_ALERT_PCT=80        # 1er seuil d'alerte (%)
QUIET_HOURS_START=             # ex 23:30 — vide = désactivé
QUIET_HOURS_END=               # ex 07:00 (plages nocturnes gérées)

# ── Rituels quotidiens ──────────────────────────────────────
RITUALS_ENABLED=true           # roast, debrief, citation, anniversaires
ROAST_TIME=18:30               # critique sèche des tâches non faites
DEBRIEF_TIME=21:45             # bilan de journée (voix concerned) + score figé
QUOTE_TIME=07:00               # citation ironique du jour (widget TV)
BIRTHDAY_CHECK_TIME=08:00      # anniversaires des contacts (people.birthday)
RITUALS_TTS=true               # roast/debrief prononcés par le daemon

# ── Alerte pause café ───────────────────────────────────────
BREAK_ALERT_MINUTES=90         # écran continu avant alerte (0 = off)
BREAK_GAP_MINUTES=15           # trou considéré comme une vraie pause
BREAK_COOLDOWN_MINUTES=90      # délai minimal entre deux alertes

# ── Debrief hebdo vocal + mood tracking discret ─────────────
WEEKLY_DEBRIEF_TIME=21:00      # dimanche soir — bilan complet de semaine (TTS)
MOOD_SIGNAL_TIME=23:15         # signal comportemental quotidien (aucun diagnostic)

# ── Présence au bureau (détection par le son) ───────────────
PRESENCE_ENABLED=true          # micro daemon audio requis (AUDIO_DAEMON_ENABLED=true)
PRESENCE_TIMEOUT_MIN=60        # silence avant de considérer un départ
PRESENCE_NOISE_RMS=0.015       # seuil de bruit ambiant (< seuil parole 0.02)
PRESENCE_GREETING=Vous êtes là, Monsieur. Bon retour.

# ── Binge streaming + retour tardif ─────────────────────────
BINGE_ALERT_MINUTES=120        # streaming continu avant commentaire sec (0 = off)
BINGE_GAP_MINUTES=20
STREAMING_APPS=netflix,youtube,twitch,prime video,disney,plex,molotov,mycanal
LATE_RETURN_ENABLED=true       # « Rentrez, Monsieur » si dehors après l'heure
LATE_RETURN_HOUR=23

# ── Auto-résumé de réunions (opt-in, micro daemon audio) ────
MEETING_CAPTURE_ENABLED=false  # capture les transcriptions ambiantes (texte uniquement)
MEETING_MIN_SPEECH_S=240       # parole cumulée avant d'ouvrir une réunion
MEETING_WINDOW_MIN=15
MEETING_SILENCE_MIN=10         # silence qui clôt la réunion → résumé + actions

# ── Voix : rejeu, session persistante, TTS spéculatif ───────
SPECULATIVE_TTS_ENABLED=false  # désactivé par défaut pour le pipeline natif local
VOICE_SESSION_GRACE_S=180      # reprise de conversation après coupure réseau courte

# ── Migrations SQLite versionnées (backup automatique préalable) ──
DB_MIGRATIONS_DIR=./database/migrations
DB_MIGRATIONS_AUTO_APPLY=true   # applique les migrations en attente au démarrage

# ── Détection de régression de performance ──────────────────
PERF_REGRESSION_THRESHOLD_PCT=40   # % plus lent que la référence = régression
PERF_BASELINE_WINDOW=5             # nb de benchmarks pour la médiane de référence

# ── Scan de code dupliqué ────────────────────────────────────
DUPLICATE_SCAN_ENABLED=true
DUPLICATE_SCAN_MIN_LINES=6
DUPLICATE_SCAN_DIRS=agents,scripts,integrations,database

# ── Audit sécurité (secrets, patterns dangereux) ────────────
SECURITY_AUDIT_ENABLED=true
SECURITY_AUDIT_DIRS=agents,scripts,integrations,database,main.py,config.py,llm.py,actions.py
SECURITY_AUTO_FIX_ENABLED=false   # redaction mécanique des secrets détectés (opt-in)

# ── Génération auto de tests manquants (opt-in, coûte des tokens) ──
AUTO_TEST_GEN_ENABLED=false
AUTO_TEST_GEN_TARGET_DIRS=        # vide = désactivé même si AUTO_TEST_GEN_ENABLED=true
AUTO_TEST_GEN_MAX_PER_RUN=5

# ── DevAgent : PR auto, déploiement staging, autorun ─────────
DEVAGENT_AUTO_PR=true
DEVAGENT_AUTO_DEPLOY_STAGING=true
DEVAGENT_AUTORUN_MAX_INTERVIEW_ROUNDS=6

# ── CI locale (pré-commit) ───────────────────────────────────
LOCAL_CI_RUN_FRONTEND_BUILD=false

# ── Self-healing (diagnostic + patch réversible, désactivé par défaut) ──
SELF_HEALING_ENABLED=false
SELF_HEALING_AUTO_APPLY=false
SELF_HEALING_CRASH_THRESHOLD=3
SELF_HEALING_REGRESSION_WINDOW_MIN=15   # récidive sous ce délai après un patch = rollback auto
SELF_HEALING_COOLDOWN_MIN=60            # pause avant un nouveau patch après un échec

# ── Lot 1 : prédiction messages, lieux/opportunités, doomscroll,
# procrastination, journal JARVIS, jours exceptionnels/chance ─
MESSAGE_PREDICTION_LOOKBACK_DAYS=60   # historique iMessage analysé pour la prédiction
FAVORITE_PLACE_MIN_VISITS=5           # visites minimum pour qu'un lieu soit « favori »
OPPORTUNITY_MIN_DAYS_NAMED=30         # jours sans visite avant « opportunité manquée »
OPPORTUNITY_MAX_VISITS=0              # réservé (non utilisé pour l'instant)
DOOMSCROLL_APPS=instagram,tiktok,twitter,x,reddit,facebook,snapchat,threads
DOOMSCROLL_DAILY_MINUTES=90           # seuil quotidien avant notification
PROCRASTINATION_ABANDONED_DAYS=30     # tâche non terminée depuis N jours = procrastinée
PROCRASTINATION_HOURLY_VALUE=0        # taux horaire pour estimation monétaire (0 = désactivé)
JARVIS_JOURNAL_ENABLED=true           # journal quotidien tenu par JARVIS (point de vue majordome)
JARVIS_JOURNAL_TIME=23:50

# ── Verrouillage app (auth.py) ────────────────────────────────
# Aucun secret configuré au premier démarrage : la première visite propose
# de définir un code (PIN/passphrase, 4 caractères minimum) — fail-closed
# tant que ce n'est pas fait (aucune donnée servie).
SESSION_COOKIE_NAME=jarvis_session
SESSION_MAX_AGE_DAYS=30                # expiration absolue d'une session
SESSION_INACTIVITY_DAYS=14             # ré-émise à chaque requête active (glissante)
AUTH_LOCKOUT_MAX_ATTEMPTS=5            # échecs avant verrou anti-brute-force
AUTH_LOCKOUT_MINUTES=15
AUTO_LOCK_MINUTES=5                    # verrouillage écran (client) après inactivité
# HTTPS (requis pour le microphone en acces distant — getUserMedia exige
# un contexte securise : HTTPS ou localhost). Voir scripts/generate_certs.sh
# pour generer un certificat auto-signe.
WEB_HTTPS=false                        # true → cookie de session "Secure" + HSTS + SSL

# ── Jetons pour intégrations non-navigateur ──────────────────
# Vide = /api/location (Shortcuts iOS) reste ouvert (rétro-compatible mais
# déconseillé dès que l'app quitte un LAN totalement fermé).
LOCATION_API_TOKEN=

# ── Application Android / Firebase Cloud Messaging ──────────
# Le JSON est une clé privée serveur Firebase Admin : ne jamais le committer.
# Téléchargement : Firebase Console > Paramètres projet > Comptes de service.
FCM_SERVICE_ACCOUNT_FILE=./credentials/firebase-service-account.json
FCM_PROJECT_ID=

# ── Chiffrement des sauvegardes (optionnel, nécessite `cryptography`) ────
BACKUP_ENCRYPTION_ENABLED=false
BACKUP_ENCRYPTION_PASSPHRASE=

# ── PWA mobile — détection automatique et redirection ────────
# Active la détection mobile et la redirection vers /m/.
# La PWA est servie depuis le même port (WEB_PORT) — l'auth est partagée
# automatiquement (même origine HTTP, cookie jarvis_session).
PWA_ENABLED=true
# Répertoire du build statique PWA (Next.js output: 'export')
# Défaut : pwa/out/ — généré par `bash scripts/build_pwa.sh`
PWA_DIR=./pwa/out
# URL externe optionnelle de la PWA (si servie sur un autre port/domaine).
# Vide = servie depuis FastAPI sous /m/. Renseignée = redirection HTTP 302.
PWA_URL=
# Build responsive unifié Next.js 15. S'il est absent, web/dist reste servi.
FRONTEND_DIST_DIR=./frontend/out

# ── Mode écoute : diarisation + recherche sémantique ─────────
DIARIZATION_ENABLED=false             # activer après installation d'un moteur local de diarisation
SEMANTIC_SEARCH_MODEL=all-MiniLM-L6-v2  # embeddings locaux (sentence-transformers, optionnel)
