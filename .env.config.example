# ═══════════════════════════════════════════════════════════
# JARVIS — Configuration applicative (sans secrets)
# Copie ce fichier en .env.config et ajuste les valeurs.
# Les clés API vivent dans .env (voir .env.example).
# ═══════════════════════════════════════════════════════════

# ── DeepSeek — modèles et endpoint ───────────────────────────
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_FAST_MODEL=deepseek-v4-flash  # rapide : classification, triage, voix, auto-titre, mémoire
DEEPSEEK_MAIN_MODEL=deepseek-v4-pro    # principal : coach, journal, productivité, école

# ── Tâches lourdes ──────────────────────────────────────────
HEAVY_TASK_MAX_TOKENS=8192

# ── Dual-LLM (package jarvis/) — LOCAL MLX + DeepSeek ───────
DEEPSEEK_MODEL=deepseek-v4-pro
JARVIS_LOCAL_MODEL=mlx-community/Qwen3-30B-A3B-4bit
JARVIS_VENV=~/mlx-env
JARVIS_PII_USE_SPACY=true
JARVIS_SPACY_MODEL=fr_core_news_sm

# ── Audio (local : Qwen3-TTS MLX via TTSKit, repli Kokoro/macOS) ─
TTS_ENGINE=ttskit                              # ttskit | kokoro | edge | macos
TTS_MODEL=qwen3-tts-0.6b                       # alias → Qwen3-TTS-12Hz-0.6B-CustomVoice-6bit
TTS_LANGUAGE=fr                                # FR natif (Qwen3-TTS)
TTS_SPEAKER=Ryan                               # voix CustomVoice (homme) — sans émotion
TTS_MODEL_PATH=                                # optionnel : chemin local du modèle MLX
TTS_VOICE=fr-FR-HenriNeural                    # voix Edge FR masculine (si TTS_ENGINE=edge)
KOKORO_VOICE=bm_lewis                          # repli Kokoro (homme UK ; lang fr-fr)
KOKORO_LANG=fr-fr
MACOS_TTS_VOICE=Thomas
WAKE_WORD=jarvis

# STT local faster-whisper
STT_ENGINE=faster-whisper
STT_MODEL=large-v3-turbo
STT_LANGUAGE=fr
STT_DEVICE=auto
STT_COMPUTE_TYPE=auto
STT_ALLOW_MODEL_DOWNLOAD=false
STT_FALLBACK_MODEL=large-v3
# Alias rétrocompatibles
AUDIO_DAEMON_STT_ENGINE=faster-whisper
AUDIO_DAEMON_STT_MODEL=large-v3-turbo
AUDIO_DAEMON_STT_FALLBACK_MODEL=large-v3
AUDIO_DAEMON_ALLOW_MODEL_DOWNLOAD=false

# ── Conversation vocale (page /voice) ───────────────────────
VOICE_SILENCE_DURATION_MS=1200
VOICE_MIN_SPEECH_MS=400
VOICE_REALTIME_SILENCE_MS=550
VOICE_REALTIME_MIN_SPEECH_MS=100
VOICE_REALTIME_VAD_THRESHOLD=0.30
VOICE_STT_KEYTERMS=JARVIS,DeepSeek
VOICE_MAX_TOKENS=500

# ── Écoute continue ─────────────────────────────────────────
RECORDING_MAX_DURATION_MIN=180
RECORDING_CHUNK_SIZE_MB=20
RECORDING_SUMMARY_ONLY=false

# ── Localisation ────────────────────────────────────────────
LOCATION_TRACKING=true
LOCATION_PLACE_RADIUS=100

# ── Notifications bureau macOS ─────────────────────────────
DESKTOP_NOTIFICATIONS=true
NOTIFICATION_SOUND=Glass

WEATHER_CITY=Lille

# ── iMessage (macOS uniquement) ─────────────────────────────
IMESSAGE_TARGET=
IMESSAGE_POLLING_INTERVAL=3
IMESSAGE_PREFIX=
IMESSAGE_SOURCING_ENABLED=true
IMESSAGE_SEND_ENABLED=false
IMESSAGE_SCAN_INTERVAL=300

# ── Import iMessage ─────────────────────────────────────────
IIMPORT_BATCH_SIZE=5000
IIMPORT_MAX_RETRIES=3
IIMPORT_SYNC_INTERVAL=300

# ── Daemon iMessage ─────────────────────────────────────────
IMESSAGE_DAEMON_ENABLED=true
IMESSAGE_DAEMON_URL=http://127.0.0.1:8193
IMESSAGE_DAEMON_PORT=8193

# ── Système ─────────────────────────────────────────────────
DB_PATH=./data/jarvis.db
UPLOAD_DIR=./data/uploads
SCHOOL_OUTPUT_DIR=./data/outputs/school
DEV_PROJECTS_ROOT=./dev_projects
DEVAGENT_EXEC_TIMEOUT=120
USER_NAME=Nolann
LANGUAGE=fr
TIMEZONE=Europe/Paris
WEB_PORT=8080
WEB_HOST=0.0.0.0
WEB_HTTPS=false

# ── Accès ordinateur (macOS) ────────────────────────────────
COMPUTER_ACCESS=true
COMPUTER_SHELL=/bin/zsh
COMPUTER_TIMEOUT=30

# ── Contrôle TV ─────────────────────────────────────────────
# TV_IP=192.168.3.82
# TV_ADB_PORT=5555
# TV_MAC=f0:ed:51:02:16:34
# TV_CAST_ENABLED=true
# TV_CAST_TIMEOUT=20
# TV_DASHBOARD_URL=http://192.168.3.52:5174/

# ── Exécution de code avancée ────────────────────────────────
CODE_EXECUTOR_ENABLED=true
CODE_EXECUTOR_TIMEOUT=120
CODE_EXECUTOR_MODEL=

# ── Mode autonome /loop ─────────────────────────────────────
LOOP_UNLIMITED=true
LOOP_MAX_STEPS=0
LOOP_MAX_OUTPUT_CHARS=0
LOOP_MAX_LLM_CALLS=0
LOOP_MAX_TOKENS=1024
LOOP_MAX_CONSECUTIVE_FAILURES=3
LOOP_MODEL=
LOOP_DECISION_MODEL=

# ── Briefings ───────────────────────────────────────────────
MORNING_BRIEFING_TIME=07:30
EVENING_SUMMARY_TIME=22:00

# ── Surveillance email proactive ────────────────────────────
EMAIL_CHECK_INTERVAL=120

# ── Daemon JARVIS ───────────────────────────────────────────
DAEMON_ENABLED=true
SCREEN_WATCHER_ENABLED=true
SCREEN_WATCHER_INTERVAL=30
SCREEN_CHANGE_THRESHOLD=5
SCREEN_ANALYSIS_THRESHOLD=40
SCREEN_MAX_ANALYSIS_WIDTH=640
SCREEN_JPEG_QUALITY=50
SCREEN_OLLAMA_MIN_INTERVAL_S=120
SCREEN_VISION_MODEL=qwen2.5-vl:7b
TRIAGE_MODEL=qwen2.5:7b
OLLAMA_URL=http://localhost:11434

DEVICE_ID=
DEVICE_NAME=Mac Mini M4

WAKE_WORD_ENABLED=false
DAEMON_TTS_COOLDOWN=30

# ── Audio Daemon ────────────────────────────────────────────
AUDIO_DAEMON_ENABLED=false
AUDIO_DAEMON_SPEECH_THRESHOLD=0.02
AUDIO_DAEMON_SILENCE_MS=1200
AUDIO_DAEMON_MIN_SPEECH_MS=600
AUDIO_DAEMON_MAX_UTTERANCE_S=15
AUDIO_DAEMON_CONVERSATION_TIMEOUT=45.0
AUDIO_DAEMON_INPUT_DEVICE=
AUDIO_DAEMON_WAKE_SOUND=true
AUDIO_DAEMON_STT_ENGINE=faster-whisper
AUDIO_DAEMON_STT_MODEL=large-v3-turbo
AUDIO_DAEMON_STT_FALLBACK_MODEL=large-v3
SILERO_VAD_THRESHOLD=0.5

# ── Fiabilité ───────────────────────────────────────────────
BACKUP_ENABLED=true
BACKUP_DIR=./data/backups
BACKUP_KEEP=7
RETENTION_SCREEN_DAYS=30
RETENTION_LOCATION_DAYS=90
RETENTION_NOTIF_READ_DAYS=60
RETENTION_LLM_LOGS_DAYS=90
LLM_BUDGET_MONTHLY=20
LLM_BUDGET_ALERT_PCT=80
QUIET_HOURS_START=
QUIET_HOURS_END=

# ── Rituels quotidiens ──────────────────────────────────────
RITUALS_ENABLED=true
ROAST_TIME=18:30
DEBRIEF_TIME=21:45
QUOTE_TIME=07:00
BIRTHDAY_CHECK_TIME=08:00
RITUALS_TTS=true

# ── Alertes et présence ─────────────────────────────────────
BREAK_ALERT_MINUTES=90
BREAK_GAP_MINUTES=15
BREAK_COOLDOWN_MINUTES=90
WEEKLY_DEBRIEF_TIME=21:00
MOOD_SIGNAL_TIME=23:15
PRESENCE_ENABLED=true
PRESENCE_TIMEOUT_MIN=60
PRESENCE_NOISE_RMS=0.015
PRESENCE_GREETING=Vous êtes là, Monsieur. Bon retour.
BINGE_ALERT_MINUTES=120
BINGE_GAP_MINUTES=20
STREAMING_APPS=netflix,youtube,twitch,prime video,disney,plex,molotov,mycanal
LATE_RETURN_ENABLED=true
LATE_RETURN_HOUR=23

# ── Réunions et voix ────────────────────────────────────────
MEETING_CAPTURE_ENABLED=false
MEETING_MIN_SPEECH_S=240
MEETING_WINDOW_MIN=15
MEETING_SILENCE_MIN=10
SPECULATIVE_TTS_ENABLED=true
VOICE_SESSION_GRACE_S=180

# ── Migrations et qualité ───────────────────────────────────
DB_MIGRATIONS_DIR=./database/migrations
DB_MIGRATIONS_AUTO_APPLY=true
PERF_REGRESSION_THRESHOLD_PCT=40
PERF_BASELINE_WINDOW=5
DUPLICATE_SCAN_ENABLED=true
DUPLICATE_SCAN_MIN_LINES=6
DUPLICATE_SCAN_DIRS=agents,scripts,integrations,database
SECURITY_AUDIT_ENABLED=true
SECURITY_AUDIT_DIRS=agents,scripts,integrations,database,main.py,config.py,llm.py,actions.py
SECURITY_AUTO_FIX_ENABLED=false
AUTO_TEST_GEN_ENABLED=false
AUTO_TEST_GEN_TARGET_DIRS=
AUTO_TEST_GEN_MAX_PER_RUN=5
DEVAGENT_AUTO_PR=true
DEVAGENT_AUTO_DEPLOY_STAGING=true
DEVAGENT_AUTORUN_MAX_INTERVIEW_ROUNDS=6
LOCAL_CI_RUN_FRONTEND_BUILD=false
SELF_HEALING_ENABLED=false
SELF_HEALING_AUTO_APPLY=false
SELF_HEALING_CRASH_THRESHOLD=3
SELF_HEALING_REGRESSION_WINDOW_MIN=15
SELF_HEALING_COOLDOWN_MIN=60

# ── Lot 1 : prédictions, lieux, doomscroll… ─────────────────
MESSAGE_PREDICTION_LOOKBACK_DAYS=60
FAVORITE_PLACE_MIN_VISITS=5
OPPORTUNITY_MIN_DAYS_NAMED=30
OPPORTUNITY_MAX_VISITS=0
DOOMSCROLL_APPS=instagram,tiktok,twitter,x,reddit,facebook,snapchat,threads
DOOMSCROLL_DAILY_MINUTES=90
PROCRASTINATION_ABANDONED_DAYS=30
PROCRASTINATION_HOURLY_VALUE=0
JARVIS_JOURNAL_ENABLED=true
JARVIS_JOURNAL_TIME=23:50

# ── Verrouillage app ────────────────────────────────────────
SESSION_COOKIE_NAME=jarvis_session
SESSION_MAX_AGE_DAYS=30
SESSION_INACTIVITY_DAYS=14
AUTH_LOCKOUT_MAX_ATTEMPTS=5
AUTH_LOCKOUT_MINUTES=15
AUTO_LOCK_MINUTES=5
DEVICE_PAIRING_TTL_MINUTES=10
DEVICE_PAIRING_MAX_ATTEMPTS=5
DEVICE_PAIRING_ATTEMPT_WINDOW_MINUTES=10
DEVICE_PAIRING_LOCKOUT_MINUTES=15

BACKUP_ENCRYPTION_ENABLED=false

# ── PWA / frontend ──────────────────────────────────────────
PWA_ENABLED=true
PWA_DIR=./pwa/out
PWA_URL=
FRONTEND_DIST_DIR=./frontend/out
WEB_DIST_DIR=./web/dist

# Style MapLibre (Cartographie desktop) — OpenFreeMap Dark, sans clé API.
# Remplaçable par un style local / PMTiles (voir Architecture/01_CARTOGRAPHIE.md).
VITE_MAP_STYLE_URL=https://tiles.openfreemap.org/styles/dark

# ── Mode écoute ─────────────────────────────────────────────
DIARIZATION_ENABLED=true
SEMANTIC_SEARCH_MODEL=all-MiniLM-L6-v2

# ── Routage cognitif / Cursor / Autonomie (2026) ─────────────
VOICE_REASONING_MODEL=deepseek-v4-flash
MAIN_REASONING_MODEL=deepseek-v4-pro
OLLAMA_REASONING_ENABLED=false
CURSOR_DELEGATION_ENABLED=true
CURSOR_CLI_PATH=
CURSOR_DEFAULT_TIMEOUT_SEC=1800
CURSOR_MAX_CONCURRENT_JOBS=2
CURSOR_WORKTREE_ROOT=.jarvis/worktrees
CURSOR_ALLOW_COMMIT=true
CURSOR_ALLOW_PUSH=false
CURSOR_ALLOW_PR=false
CURSOR_ALLOW_MERGE=false
SELF_REPAIR_ENABLED=false
SELF_IMPROVEMENT_ENABLED=false
SELF_MODIFICATION_MODE=pr_only
SELF_IMPROVEMENT_SCHEDULE=weekly
